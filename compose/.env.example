# Local dev environment overrides.
# Copy to .env (which is gitignored) and tweak as you like.
#
# Defaults are intentionally non-standard so two CDP-flavoured stacks can
# coexist on the same laptop. Override here if you want plain :9083 etc.

# --- ports (avoid clashing with anything you run on the host) ---
POSTGRES_PORT=15433
HMS_THRIFT_PORT=19083
HMS_WEBUI_PORT=10012
DS_PORT=12345
DS_PYTHON_GATEWAY_PORT=25333

# --- HMS metadata DB ---
POSTGRES_DB=metastore
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive
